# Variables por app (Vite). Copia el bloque que corresponda a tu app en apps/<app>/.env

# Foco (puerto 5173)
# VITE_API_URL=http://localhost:5000
# VITE_FRONTEND_URL=http://localhost:5173

# Atta (puerto 5174)
# VITE_API_URL=http://localhost:5000
# VITE_FRONTEND_URL=http://localhost:5174

# Pulso (puerto 5175)
# VITE_API_URL=http://localhost:5000
# VITE_FRONTEND_URL=http://localhost:5175

# Producción (ejemplo)
# VITE_API_URL=https://api.attadia.com
# VITE_FRONTEND_URL=https://foco.attadia.com

VITE_APP_NAME=attadia technologies
VITE_APP_VERSION=1.1.0
